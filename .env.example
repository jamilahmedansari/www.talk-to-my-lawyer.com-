# =============================================================================
# Talk to My Lawyer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# Variables prefixed with VITE_ are exposed to the browser bundle at build
# time. Never put secrets in VITE_ variables.
#
# Required = the app will not start / a feature will be broken without it.
# Optional = the app degrades gracefully; the feature is simply disabled.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Node environment. Set to "production" on your hosting platform.
# Required.
NODE_ENV=development

# Port the Express server listens on locally.
# Optional — defaults to 3000.
PORT=3000

# Secret used to sign session cookies (JWT).
# Generate with: openssl rand -base64 32
# Required.
JWT_SECRET=


# -----------------------------------------------------------------------------
# SUPABASE  (https://supabase.com/dashboard/project/lguqhibpxympxvwqpedf)
# Project ref: lguqhibpxympxvwqpedf
# -----------------------------------------------------------------------------

# Your Supabase project URL. Found in: Project Settings → API → Project URL.
# Required (server + client).
SUPABASE_URL=https://lguqhibpxympxvwqpedf.supabase.co
VITE_SUPABASE_URL=https://lguqhibpxympxvwqpedf.supabase.co

# Supabase anon/publishable key. Safe to expose in the browser.
# Found in: Project Settings → API → Project API keys → anon / public.
# Required (client — Realtime subscriptions + Auth session).
VITE_SUPABASE_ANON_KEY=
# Alias accepted by the client (either one works):
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key. NEVER expose this in the browser.
# Used by the server for: Storage uploads, admin DB writes, Auth admin.
# Found in: Project Settings → API → Project API keys → service_role.
# Required (server).
SUPABASE_SERVICE_ROLE_KEY=

# Direct PostgreSQL connection string for Drizzle ORM and migrations.
# Found in: Project Settings → Database → Connection string → URI (use
# the "Transaction" pooler URL for serverless, or the direct URL for
# long-lived server processes).
# Required (server + drizzle-kit).
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-2.pooler.supabase.com:6543/postgres
# Alias accepted by db.ts:
SUPABASE_DATABASE_URL=


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------

# The Supabase auth.users UUID of the app owner / admin account.
# Used to grant the first user admin role automatically on signup.
# Found by running: SELECT id FROM auth.users WHERE email = 'your@email.com';
# Required (server — supabaseAuth.ts).
OWNER_OPEN_ID=


# -----------------------------------------------------------------------------
# APP URLS  (used for CORS, email links, Stripe redirect URLs)
# -----------------------------------------------------------------------------

# Primary public URL of the app (no trailing slash).
# Required.
APP_BASE_URL=https://www.talk-to-my-lawyer.com

# Admin dashboard URL if hosted separately (no trailing slash).
# Optional — falls back to APP_BASE_URL.
ADMIN_APP_BASE_URL=

# Staging URL, added to the CORS allowlist automatically.
# Optional.
STAGING_APP_BASE_URL=

# Additional comma-separated origins to allow in CORS.
# Example: https://preview.talk-to-my-lawyer.com,https://staging.example.com
# Optional.
CORS_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# AI PIPELINE
# -----------------------------------------------------------------------------

# Anthropic Claude API key — used for letter drafting and assembly stages.
# Get from: https://console.anthropic.com/settings/keys
# Required (server — pipeline.ts).
ANTHROPIC_API_KEY=

# Perplexity Sonar API key — used for the research stage.
# Get from: https://www.perplexity.ai/settings/api
# Required (server — pipeline.ts).
PERPLEXITY_API_KEY=

# OpenAI API key — used as a fallback / utility model.
# Get from: https://platform.openai.com/api-keys
# Optional (server — pipeline.ts).
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# N8N WORKFLOW AUTOMATION  (optional — direct pipeline is used by default)
# -----------------------------------------------------------------------------

# Set to "true" to route letter generation through n8n instead of the
# built-in 3-stage pipeline. Useful for debugging or experimentation.
# Optional — defaults to false (direct pipeline).
N8N_PRIMARY=false

# n8n webhook URL that triggers the letter generation workflow.
# Required only when N8N_PRIMARY=true.
N8N_WEBHOOK_URL=

# Shared secret used to authenticate n8n callbacks to the Express server.
# Generate with: openssl rand -hex 32
# Required only when N8N_PRIMARY=true.
N8N_CALLBACK_SECRET=


# -----------------------------------------------------------------------------
# EMAIL  (Resend — https://resend.com)
# -----------------------------------------------------------------------------

# Resend API key.
# Get from: https://resend.com/api-keys
# Required (server — email.ts).
RESEND_API_KEY=

# From address used for all transactional emails.
# Must be a verified domain in your Resend account.
# Optional — defaults to noreply@talktomylawyer.com.
RESEND_FROM_EMAIL=noreply@talktomylawyer.com


# -----------------------------------------------------------------------------
# STRIPE  (https://dashboard.stripe.com)
# -----------------------------------------------------------------------------

# Stripe secret key. NEVER expose this in the browser.
# Get from: Developers → API keys → Secret key.
# Required (server).
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret. Used to verify webhook payloads.
# Get from: Developers → Webhooks → your endpoint → Signing secret.
# Required (server — stripeWebhook.ts).
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe publishable key. Safe to expose in the browser.
# Get from: Developers → API keys → Publishable key.
# Required (client — Stripe.js).
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...


# -----------------------------------------------------------------------------
# RATE LIMITING  (Upstash Redis — https://console.upstash.com)
# -----------------------------------------------------------------------------

# Upstash Redis REST URL.
# Get from: Upstash Console → your database → REST API → UPSTASH_REDIS_REST_URL.
# Required (server — rateLimiter.ts).
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token.
# Get from: Upstash Console → your database → REST API → UPSTASH_REDIS_REST_TOKEN.
# Required (server — rateLimiter.ts).
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# CRON JOBS
# -----------------------------------------------------------------------------

# Secret used to authenticate cron job HTTP requests (e.g. from Vercel Cron,
# GitHub Actions, or an external scheduler).
# The caller must send: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
# Required (server — draftReminders.ts).
CRON_SECRET=


# -----------------------------------------------------------------------------
# ERROR MONITORING  (Sentry — https://sentry.io)
# -----------------------------------------------------------------------------

# Sentry DSN for the Express server.
# Get from: Sentry → your project → Settings → Client Keys (DSN).
# Optional — error monitoring is disabled when not set.
SENTRY_DSN=

# Sentry DSN for the React client.
# Optional — error monitoring is disabled when not set.
VITE_SENTRY_DSN=

# Sentry organisation slug (used by sentry-cli / build plugin for source maps).
# Optional — only needed for source map uploads during CI/CD.
SENTRY_ORG=

# Sentry project slug.
# Optional — only needed for source map uploads during CI/CD.
SENTRY_PROJECT=

# Sentry auth token for source map uploads.
# Get from: Sentry → User Settings → Auth Tokens.
# Optional — only needed for source map uploads during CI/CD.
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# ANALYTICS  (Umami or compatible — optional)
# -----------------------------------------------------------------------------

# Analytics ingest endpoint.
# Optional — analytics are disabled when not set.
VITE_ANALYTICS_ENDPOINT=

# Website ID registered in your analytics platform.
# Optional.
VITE_ANALYTICS_WEBSITE_ID=


# -----------------------------------------------------------------------------
# LEGACY / DEPRECATED  (safe to leave blank — not used in active code paths)
# -----------------------------------------------------------------------------

# These variables were used by the Manus Forge API proxy and Manus OAuth.
# They are no longer required after the Supabase Auth + Supabase Storage
# migration. The modules that reference them (server/_core/sdk.ts,
# server/_core/chat.ts, etc.) are unused stubs kept for reference only.
# Leave blank or remove entirely.

VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
FORGE_API_KEY=
